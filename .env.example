# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Optional overrides (defaults match the site contact details)
# CONTACT_FROM_EMAIL=hello@mail.saurahanepal.com
# CONTACT_TO_EMAIL=your-inbox@example.com

# Inbound mail (Resend → /api/webhooks/resend forwards to CONTACT_TO_EMAIL)
# RESEND_WEBHOOK_SECRET=whsec_xxxxxxxx

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin panel (/admin) — use a strong password in production
ADMIN_PASSWORD=your_secure_admin_password

# Team content calendar (/team) — shared password for view-only team access
TEAM_PASSWORD=your_team_password
